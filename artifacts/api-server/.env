# Get this from neon.tech after creating a database
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/khabar

# Get this from platform.openai.com
OPENAI_API_KEY=your_openai_key_here

# Secret for JWT tokens - use any long random string
JWT_SECRET=change_this_to_a_long_random_secret_string_at_least_32_chars

PORT=3000
NODE_ENV=production
